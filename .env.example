# Copy this file to .env and adjust to your setup

# -------------------------------------------------------------------
# Qdrant — vector database
# -------------------------------------------------------------------
# Local: run with `docker compose up -d`
# Remote: open a tunnel first: ssh -fNL 6333:localhost:6333 your-vps-host
QDRANT_URL=http://localhost:6333

# -------------------------------------------------------------------
# Ollama — local embedding model
# -------------------------------------------------------------------
# Install: https://ollama.com — then: ollama pull nomic-embed-text
OLLAMA_URL=http://localhost:11434

# -------------------------------------------------------------------
# Remote Qdrant (only needed if Qdrant runs on a remote host)
# -------------------------------------------------------------------
# SSH alias of the host where Qdrant runs (must be in ~/.ssh/config)
# Used by sync-and-index.sh to open an SSH tunnel automatically.
# Leave blank if Qdrant runs locally.
VPS_HOST=
QDRANT_VPS_PORT=6333

# -------------------------------------------------------------------
# Secondary Claude source — pull sessions from another machine (optional)
# -------------------------------------------------------------------
# If you run Claude Code on a second machine (e.g. a VPS), set these
# to pull its sessions here and index them alongside your local ones.
# Leave blank to skip.
VPS_SOURCE_HOST=        # SSH alias of the remote machine
VPS_SOURCE_USER=        # Unix user on that machine (e.g. mcpgw)
VPS_SOURCE_OBSIDIAN_DIR= # Obsidian vault path on that machine (optional)

# -------------------------------------------------------------------
# GitHub PR indexing (optional)
# -------------------------------------------------------------------
# GitHub org or user whose repos will be indexed by etl/github/prs.py
# Leave blank to skip PR indexing.
GITHUB_ORG=

# -------------------------------------------------------------------
# Push sources to a remote embedding host (scripts/push-to-embedding-host.sh)
# -------------------------------------------------------------------
# Only needed if another machine runs the ETL and you push sources to it.
# Leave blank if you run the ETL locally.
EMBEDDING_HOST=         # SSH alias of the machine that runs the ETL
REMOTE_DIR=             # Path on that machine to store synced sources
OBSIDIAN_DIR=           # Local Obsidian vault path to sync (e.g. ~/obsidian)

# -------------------------------------------------------------------
# Project name cleanup
# -------------------------------------------------------------------
# Claude Code stores sessions in ~/.claude/projects/ using folder names
# derived from the full path of each project, replacing "/" with "-".
# For example, a project at /home/alice/work/myapp becomes:
#   -home-alice-work-myapp
#
# PROJECT_PATH_STRIP lets you remove the noisy prefix so only the
# project name remains (e.g. "myapp" instead of "-home-alice-work-myapp").
#
# How to fill it:
#   1. Run: ls ~/.claude/projects/
#   2. Identify the common prefix across folders (e.g. "-home-alice-")
#   3. List all fragments to strip, separated by colons (:)
#
# Example for a user "alice" on Linux + a VPS user "bot":
#   PROJECT_PATH_STRIP=-home-alice-:-home-bot-:work-projects-
#
# Example for a Mac user "alice":
#   PROJECT_PATH_STRIP=-Users-alice-:-Users-alice-Documents-
PROJECT_PATH_STRIP=

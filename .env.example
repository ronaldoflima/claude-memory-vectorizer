# Copy this file to .env and adjust to your setup

# Qdrant
QDRANT_URL=http://localhost:6333

# Ollama
OLLAMA_URL=http://localhost:11434

# SSH host running Qdrant (used for tunnel in sync-and-index.sh)
VPS_HOST=your-vps-host
QDRANT_VPS_PORT=6333

# Secondary Claude source on the VPS (optional)
# Leave blank to skip VPS session indexing
VPS_SOURCE_HOST=your-vps-host
VPS_SOURCE_USER=mcpgw

# GitHub org/user for PR indexing (used in etl/github/prs.py)
GITHUB_ORG=your-org-or-user

# push-to-embedding-host.sh
EMBEDDING_HOST=your-embedding-host
REMOTE_DIR=/home/youruser/claude-vectorizer-sources
OBSIDIAN_DIR=~/obsidian

# Project name cleanup: colon-separated path fragments to strip from
# Claude's internal project directory names to produce readable project names.
# Example: -Users-youruser-projects-:-home-youruser-
PROJECT_PATH_STRIP=
